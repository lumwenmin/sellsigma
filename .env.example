# Reddit (users provide their own credentials)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=sellsigma/1.0

# Supabase
# SUPABASE_URL        — used by host scripts (test_scraper.py). Use 127.0.0.1.
# SUPABASE_DOCKER_URL — used by the backend Docker container. Use host.docker.internal.
#                       (Inside Docker, 127.0.0.1 is the container itself, not your Mac.)
# Prod: both can be https://<project>.supabase.co
SUPABASE_URL=                        # e.g. http://127.0.0.1:54321
SUPABASE_DOCKER_URL=                 # e.g. http://host.docker.internal:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=           # backend + scraper only, never frontend

# LLM
GEMINI_API_KEY=                      # Google Gemini (used by scraper classifier)
HUGGINGFACE_API_KEY=

# App
VITE_API_URL=http://localhost:8000   # frontend → backend; override in prod
VITE_SUPABASE_URL=                   # same as SUPABASE_URL — exposed to frontend
VITE_SUPABASE_ANON_KEY=              # same as SUPABASE_ANON_KEY — safe to expose
